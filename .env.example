# Database Configuration (mapped to host port 5435 to avoid conflicts)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5435/evidencesplit
SQL_ECHO=false

# Production Compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-url-safe-password
POSTGRES_DB=evidencesplit

# Initial frontend Demo mode switch state
DEMO_MODE=false

# AI Providers
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_GENERATION_MODEL=gemini-3.5-flash
OPENROUTER_API_KEY=
OPENROUTER_GENERATION_MODEL=openai/gpt-4.1-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=384
VITE_API_URL=http://localhost:8000

# Academic Discovery
OPENALEX_API_KEY=
UNPAYWALL_EMAIL=your-email@example.com
OPENALEX_RESULT_LIMIT=20
TARGET_LIVE_PAPERS=5
MAX_LIVE_FULL_TEXT_PAPERS=5
REMOTE_DOWNLOAD_TIMEOUT_SECONDS=20
MAX_REMOTE_PDF_SIZE_MB=25
